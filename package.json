{
  "name": "wardroom",
  "version": "0.2.0",
  "description": "One terminal harness for parallel AI coding agents on one checkout. Claude, Codex, and Gemini plan, talk, and build together - no worktrees, no merge conflicts.",
  "type": "module",
  "main": "dist/mcp.js",
  "types": "dist/mcp.d.ts",
  "files": [
    "dist",
    "scripts",
    "CLAUDE.md",
    "GEMINI.md",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "wardroom": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli.js mcp",
    "dev": "node --watch --experimental-strip-types src/cli.ts mcp",
    "test": "node --test --experimental-strip-types test/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agents",
    "orchestration",
    "coordination",
    "parallel",
    "mcp",
    "claude",
    "codex",
    "gemini",
    "harness"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22"
  }
}
